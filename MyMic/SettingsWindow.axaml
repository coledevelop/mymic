<local:SecondaryWindow xmlns="https://github.com/avaloniaui"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:local="clr-namespace:MyMic"
                       x:Class="MyMic.SettingsWindow"
                       Title="Settings"
                       Width="780" Height="580"
                       MinWidth="520" MinHeight="380"
                       WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <Style Selector="Button.recording">
            <Setter Property="Background" Value="#3b82f6" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Styles>

    <StackPanel Spacing="32" Margin="48,40">
        <TextBlock Text="Settings"
                   FontSize="22"
                   FontWeight="SemiBold" />

        <StackPanel Spacing="10">
            <TextBlock Text="Toggle mute hotkey"
                       FontSize="14"
                       Opacity="0.7" />
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button x:Name="HotkeyButton"
                        Click="OnHotkeyButtonClick"
                        MinWidth="280"
                        HorizontalContentAlignment="Center"
                        Padding="16,10"
                        FontSize="14" />
                <Button x:Name="ClearButton"
                        Click="OnClearClick"
                        Content="Clear"
                        Padding="16,10" />
            </StackPanel>
            <TextBlock x:Name="HelpText"
                       FontSize="12"
                       Opacity="0.55"
                       Text="Click the field, then press a key combo. Esc to cancel." />
        </StackPanel>
    </StackPanel>
</local:SecondaryWindow>
