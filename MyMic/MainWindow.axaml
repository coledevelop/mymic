<local:AppWindow xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:local="clr-namespace:MyMic"
                 x:Class="MyMic.MainWindow"
                 Title="MyMic"
                 Width="1100" Height="720"
                 MinWidth="720" MinHeight="480"
                 WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="Button.icon">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.icon /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#14808080" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="Button.icon:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#28808080" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
    </Window.Styles>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="12,12,12,0"
                    Spacing="4">
            <Button Classes="icon"
                    Click="OnOpenSettings"
                    ToolTip.Tip="Settings (⌘,)"
                    Width="44" Height="44">
                <PathIcon Width="24" Height="24"
                          Data="M19.14,12.94c0.04-0.3,0.06-0.61,0.06-0.94c0-0.32-0.02-0.64-0.07-0.94l2.03-1.58c0.18-0.14,0.23-0.41,0.12-0.61l-1.92-3.32c-0.12-0.22-0.37-0.29-0.59-0.22l-2.39,0.96c-0.5-0.38-1.03-0.7-1.62-0.94L14.4,2.81c-0.04-0.24-0.24-0.41-0.48-0.41h-3.84c-0.24,0-0.43,0.17-0.47,0.41L9.25,5.35C8.66,5.59,8.12,5.92,7.63,6.29L5.24,5.33c-0.22-0.08-0.47,0-0.59,0.22L2.74,8.87C2.62,9.08,2.66,9.34,2.86,9.48l2.03,1.58C4.84,11.36,4.8,11.69,4.8,12s0.02,0.64,0.07,0.94l-2.03,1.58c-0.18,0.14-0.23,0.41-0.12,0.61l1.92,3.32c0.12,0.22,0.37,0.29,0.59,0.22l2.39-0.96c0.5,0.38,1.03,0.7,1.62,0.94l0.36,2.54c0.05,0.24,0.24,0.41,0.48,0.41h3.84c0.24,0,0.44-0.17,0.47-0.41l0.36-2.54c0.59-0.24,1.13-0.56,1.62-0.94l2.39,0.96c0.22,0.08,0.47,0,0.59-0.22l1.92-3.32c0.12-0.22,0.07-0.47-0.12-0.61L19.14,12.94z M12,15.6c-1.98,0-3.6-1.62-3.6-3.6s1.62-3.6,3.6-3.6s3.6,1.62,3.6,3.6S13.98,15.6,12,15.6z" />
            </Button>
            <Button Classes="icon"
                    Click="OnOpenAbout"
                    ToolTip.Tip="About MyMic"
                    Width="44" Height="44">
                <PathIcon Width="24" Height="24"
                          Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M12,20c-4.41,0-8-3.59-8-8s3.59-8,8-8s8,3.59,8,8S16.41,20,12,20z M11,18h2v-2h-2V18z M13.6,11.5C14.36,10.85,15,10.06,15,9c0-1.66-1.34-3-3-3S9,7.34,9,9h2c0-0.55,0.45-1,1-1s1,0.45,1,1c0,1-1.5,1.13-1.5,2.75V13h2V12.5C13.5,12,13.6,11.5,13.6,11.5z" />
            </Button>
        </StackPanel>

        <Button Grid.Row="1"
                Classes="icon"
                Click="OnMicClick"
                ToolTip.Tip="Toggle microphone"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="24">
            <Image x:Name="MicImage"
                   Width="240" Height="240"
                   Stretch="Uniform" />
        </Button>
    </Grid>
</local:AppWindow>
